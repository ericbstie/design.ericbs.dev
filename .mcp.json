{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless",
        "--isolated",
        "--executablePath",
        "/opt/pw-browsers/chromium-1194/chrome-linux/chrome",
        "--chrome-arg=--no-sandbox",
        "--chrome-arg=--disable-setuid-sandbox"
      ]
    }
  }
}
