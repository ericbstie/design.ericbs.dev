{
  "name": "@ericbs/design",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun --watch src/index.ts",
    "build": "bun run build.ts",
    "build:pkg": "bun run packages/react-glass-components/build.ts",
    "publish:pkg": "bun publish --cwd packages/react-glass-components"
  },
  "dependencies": {
    "bun-plugin-tailwind": "^0.1.2",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^7.0.2"
  }
}
